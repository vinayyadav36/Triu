# ============================================
# EMPORIUMVIPANI — BACKEND ENV (JSON-DB MODE)
# ============================================
# All data is stored in server/db/*.json files.
# No external database (MongoDB, SQL, etc.) is required.

# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# JWT — CHANGE IN PRODUCTION
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRE=7d

# Razorpay (optional — COD works without it)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Sentry (optional)
SENTRY_DSN=

# Admin seed
ADMIN_EMAIL=admin@triu.com
ADMIN_PASSWORD=Admin@123
